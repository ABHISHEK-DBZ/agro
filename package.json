{
  "name": "smart-krishi-sahayak",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://abhishek-dbz.github.io/smart-krishi-sahayak",
  "scripts": {
    "dev": "vite",
    "dev:server": "cd server && npm run dev",
    "dev:fullstack": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "start": "concurrently \"npm run preview\" \"cd server && npm start\"",
    "build": "vite build",
    "build:pwa": "tsc && vite build --mode pwa",
    "build:fullstack": "npm run build && cd server && npm run build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "clean": "rm -rf dist node_modules package-lock.json && cd server && rm -rf node_modules package-lock.json",
    "install:all": "npm install && cd server && npm install",
    "predeploy": "npm run build",
    "deploy": "cross-env GITHUB_PAGES=true npm run build && gh-pages -d dist",
    "deploy:vercel": "npm run build && vercel --prod",
    "deploy:netlify": "npm run build && netlify deploy --prod --dir=dist",
    "deploy:firebase": "npm run build && firebase deploy",
    "deploy:surge": "npm run build && surge dist smart-krishi-sahayak.surge.sh",
    "deploy:azure": "npm run build && echo 'Manual Azure deployment: Upload dist folder to Azure Static Web Apps'",
    "deploy:railway": "npm run build:fullstack && railway up",
    "deploy:render": "npm run build && echo 'Render deployment: Connect your GitHub repo to Render or use render.yaml'",
    "build:render": "npm install && npm run build",
    "deploy:heroku": "npm run build:fullstack && git push heroku main",
    "start:heroku": "cd server && npm start",
    "build:github": "cross-env GITHUB_PAGES=true npm run build",
    "build:vercel": "cross-env VERCEL=true npm run build",
    "build:netlify": "cross-env NETLIFY=true npm run build",
    "docker:build": "docker build -t smart-krishi-sahayak .",
    "docker:run": "docker run -p 3000:80 smart-krishi-sahayak",
    "docker:fullstack": "docker-compose up --build",
    "analyze": "npm run build && npx vite-bundle-analyzer dist",
    "optimize": "npm run clean && npm install && npm run lint:fix && npm run type-check && npm run build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "axios": "^1.11.0",
    "firebase": "^12.4.0",
    "i18next": "^23.12.2",
    "i18next-browser-languagedetector": "^8.0.0",
    "lucide-react": "^0.412.0",
    "openai": "^5.12.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^15.0.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.28.0",
    "workbox-background-sync": "^7.1.0",
    "workbox-broadcast-update": "^7.1.0",
    "workbox-cacheable-response": "^7.1.0",
    "workbox-core": "^7.1.0",
    "workbox-expiration": "^7.1.0",
    "workbox-google-analytics": "^7.1.0",
    "workbox-navigation-preload": "^7.1.0",
    "workbox-precaching": "^7.1.0",
    "workbox-range-requests": "^7.1.0",
    "workbox-routing": "^7.1.0",
    "workbox-strategies": "^7.1.0",
    "workbox-streams": "^7.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.38",
    "sharp": "^0.34.4",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  },
  "description": "A comprehensive agriculture assistant app that provides real-time weather updates, crop information, disease detection, mandi prices, and government schemes for farmers.",
  "main": "postcss.config.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
