{
  "expo": {
    "name": "Krishi Sahayak",
    "slug": "smart-krishi-sahayak",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "backgroundColor": "#F8FAF5",
    "primaryColor": "#1B7A3D",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B7A3D"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.abhishekdbz.krishisahayak",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Krishi Sahayak uses camera to detect crop diseases and identify plant issues through image analysis.",
        "NSPhotoLibraryUsageDescription": "Krishi Sahayak needs photo library access to analyze crop disease images you upload.",
        "NSLocationWhenInUseUsageDescription": "Krishi Sahayak uses your location to provide accurate local weather data and crop recommendations.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Krishi Sahayak uses your location to provide real-time weather alerts and farming recommendations.",
        "NSMicrophoneUsageDescription": "Krishi Sahayak uses microphone for voice commands and agricultural assistance.",
        "CFBundleDisplayName": "Krishi Sahayak",
        "CFBundleName": "Krishi Sahayak",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B7A3D"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.abhishekdbz.krishisahayak",
      "versionCode": 2,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-camera",
      "expo-location",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1B7A3D"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Krishi Sahayak needs photo library access to analyze crop disease images."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "562f5329-ffa8-4b99-bbca-85e80db40801"
      },
      "env": {
        "EXPO_PUBLIC_FIREBASE_API_KEY": "$EXPO_PUBLIC_FIREBASE_API_KEY",
        "EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN": "$EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN",
        "EXPO_PUBLIC_FIREBASE_PROJECT_ID": "$EXPO_PUBLIC_FIREBASE_PROJECT_ID",
        "EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET": "$EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET",
        "EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID": "$EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID",
        "EXPO_PUBLIC_FIREBASE_APP_ID": "$EXPO_PUBLIC_FIREBASE_APP_ID"
      }
    },
    "owner": "abhishekjhadbz",
    "description": "Krishi Sahayak - Smart Agriculture Assistant for Indian Farmers. Get real-time weather updates, market prices, crop disease detection, government schemes, and expert farming advice in multiple Indian languages.",
    "keywords": [
      "krishi",
      "agriculture",
      "farming",
      "farmer",
      "crops",
      "weather",
      "market prices",
      "disease detection",
      "government schemes",
      "indian farming"
    ],
    "privacy": "public",
    "scheme": "krishi-sahayak",
    "platforms": [
      "ios",
      "android"
    ]
  }
}
