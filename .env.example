# Smart Krishi Sahayak Environment Variables

# Backend Environment Variables
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/smart-krishi-sahayak

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# External APIs
OPENWEATHER_API_KEY=your-openweather-api-key

# Google Gemini AI API Key (legacy — optional, only used by GeminiAiService)
# Get your API key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# OpenRouter AI (used by /ai-agent page)
# Sign up at https://openrouter.ai and create an API key.
# Free models include google/gemma-4-26b-a4b-it:free
VITE_OPENROUTER_API_KEY=sk-or-v1-your-key-here
VITE_OPENROUTER_MODEL=openrouter/free

# Frontend Environment Variables (for Vite)
VITE_API_BASE_URL=http://localhost:5000/api
VITE_OPENWEATHER_API_KEY=your-openweather-api-key
# Government of India Open Data — required for live mandi prices. Sign up at https://data.gov.in
VITE_DATA_GOV_API_KEY=
# NewsAPI (optional) — for agriculture news feed
VITE_NEWS_API_KEY=

# Deployment URLs
VITE_BACKEND_URL=http://localhost:5000
VITE_FRONTEND_URL=http://localhost:3000

# Application Base URL (automatically set by Azure Static Web Apps)
VITE_APP_BASE_URL=

# Azure Application Insights (automatically set by deployment)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Instructions:
# 1. Copy this file to `.env`
# 2. Replace placeholder values with your actual API keys
# 3. Make sure to add `.env` to your .gitignore file
