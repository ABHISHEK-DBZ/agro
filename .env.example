# Smart Krishi Sahayak Environment Variables

# Backend Environment Variables
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/smart-krishi-sahayak

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# External APIs
OPENWEATHER_API_KEY=your-openweather-api-key

# Google Gemini AI API Key
# Get your API key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Frontend Environment Variables (for Vite)
VITE_API_BASE_URL=http://localhost:5000/api
VITE_OPENWEATHER_API_KEY=your-openweather-api-key

# Deployment URLs
VITE_BACKEND_URL=http://localhost:5000
VITE_FRONTEND_URL=http://localhost:3000

# Application Base URL (automatically set by Azure Static Web Apps)
VITE_APP_BASE_URL=

# Azure Application Insights (automatically set by deployment)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Instructions:
# 1. Copy this file to `.env`
# 2. Replace placeholder values with your actual API keys
# 3. Make sure to add `.env` to your .gitignore file
